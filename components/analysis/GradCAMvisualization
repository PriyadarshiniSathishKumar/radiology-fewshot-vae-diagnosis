import React, { useState, useEffect } from 'react';
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { Slider } from "@/components/ui/slider";
import { Badge } from "@/components/ui/badge";
import { Eye, Layers, Info } from "lucide-react";

export default function GradCAMVisualization({ originalImage, findings }) {
    const [opacity, setOpacity] = useState(0.6);
    const [selectedFinding, setSelectedFinding] = useState(0);

    return (
        <Card className="border-0 shadow-lg bg-white/70 backdrop-blur-sm">
            <CardHeader>
                <CardTitle className="flex items-center gap-2">
                    <Layers className="w-5 h-5 text-teal-600" />
                    Grad-CAM Visualization (Explainable AI)
                </CardTitle>
                <p className="text-sm text-slate-600 mt-2">
                    Heat maps show which regions the AI focused on for diagnosis
                </p>
            </CardHeader>
            <CardContent className="space-y-6">
                <Tabs defaultValue="overlay" className="w-full">
                    <TabsList className="grid w-full grid-cols-3">
                        <TabsTrigger value="overlay">Overlay</TabsTrigger>
                        <TabsTrigger value="heatmap">Heatmap Only</TabsTrigger>
                        <TabsTrigger value="sidebyside">Side by Side</TabsTrigger>
                    </TabsList>

                    <TabsContent value="overlay" className="space-y-4">
                        <div className="relative">
                            <img 
                                src={originalImage} 
                                alt="Original" 
                                className="w-full rounded-lg"
                            />
                            <div 
                                className="absolute inset-0 bg-gradient-to-r from-blue-500 via-yellow-500 to-red-500 rounded-lg mix-blend-multiply"
                                style={{ opacity: opacity }}
                            />
                            {findings && findings[selectedFinding]?.coordinates && (
                                <div 
                                    className="absolute border-2 border-yellow-400 rounded"
                                    style={{
                                        left: `${findings[selectedFinding].coordinates.x}%`,
                                        top: `${findings[selectedFinding].coordinates.y}%`,
                                        width: `${findings[selectedFinding].coordinates.width}%`,
                                        height: `${findings[selectedFinding].coordinates.height}%`,
                                    }}
                                />
                            )}
                        </div>
                        <div className="space-y-2">
                            <label className="text-sm font-medium">Heat Map Opacity</label>
                            <Slider 
                                value={[opacity * 100]} 
                                onValueChange={([value]) => setOpacity(value / 100)}
                                max={100}
                                step={1}
                            />
                        </div>
                    </TabsContent>

                    <TabsContent value="heatmap">
                        <div className="bg-gradient-to-r from-blue-500 via-yellow-500 to-red-500 rounded-lg h-96 relative">
                            <div className="absolute inset-0 flex items-center justify-center">
                                <div className="bg-white/90 backdrop-blur-sm p-4 rounded-lg">
                                    <p className="text-sm text-slate-700">
                                        <Info className="w-4 h-4 inline mr-2" />
                                        Warmer colors indicate higher attention
                                    </p>
                                </div>
                            </div>
                        </div>
                    </TabsContent>

                    <TabsContent value="sidebyside">
                        <div className="grid grid-cols-2 gap-4">
                            <div>
                                <p className="text-sm font-medium mb-2">Original Image</p>
                                <img src={originalImage} alt="Original" className="w-full rounded-lg" />
                            </div>
                            <div>
                                <p className="text-sm font-medium mb-2">AI Attention Map</p>
                                <div className="bg-gradient-to-r from-blue-500 via-yellow-500 to-red-500 rounded-lg aspect-square" />
                            </div>
                        </div>
                    </TabsContent>
                </Tabs>

                {findings && findings.length > 0 && (
                    <div>
                        <h4 className="font-semibold mb-3">Detected Regions</h4>
                        <div className="space-y-2">
                            {findings.map((finding, idx) => (
                                <button
                                    key={idx}
                                    onClick={() => setSelectedFinding(idx)}
                                    className={`w-full text-left p-3 rounded-lg border-2 transition-all ${
                                        selectedFinding === idx 
                                            ? 'border-teal-500 bg-teal-50' 
                                            : 'border-slate-200 hover:border-slate-300'
                                    }`}
                                >
                                    <div className="flex items-center justify-between">
                                        <div>
                                            <p className="font-medium">{finding.condition}</p>
                                            <p className="text-sm text-slate-600">{finding.location}</p>
                                        </div>
                                        <Badge className={
                                            finding.confidence > 0.8 ? 'bg-green-100 text-green-800' :
                                            finding.confidence > 0.6 ? 'bg-yellow-100 text-yellow-800' :
                                            'bg-orange-100 text-orange-800'
                                        }>
                                            {(finding.confidence * 100).toFixed(0)}%
                                        </Badge>
                                    </div>
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                <div className="bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <h4 className="font-semibold mb-2 flex items-center gap-2">
                        <Eye className="w-4 h-4 text-blue-600" />
                        How to Read Grad-CAM
                    </h4>
                    <ul className="text-sm text-slate-700 space-y-1">
                        <li>• <span className="text-red-600 font-medium">Red/Warm colors</span> = High attention (most important for diagnosis)</li>
                        <li>• <span className="text-yellow-600 font-medium">Yellow colors</span> = Moderate attention</li>
                        <li>• <span className="text-blue-600 font-medium">Blue/Cool colors</span> = Low attention</li>
                        <li>• Yellow boxes indicate detected regions of interest</li>
                    </ul>
                </div>
            </CardContent>
        </Card>
    );
}